From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
Subject: [PATCH] gsl: use gnuc99 IEEE backend on FreeBSD non-x86

---
 heacore/gsl/ieee-utils/fp.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/heacore/gsl/ieee-utils/fp.c b/heacore/gsl/ieee-utils/fp.c
index 6bad73f..1e3c3be 100644
--- a/heacore/gsl/ieee-utils/fp.c
+++ b/heacore/gsl/ieee-utils/fp.c
@@ -23,7 +23,13 @@
 #elif HAVE_TRU64_IEEE_INTERFACE
 #include "fp-tru64.c"
 #elif HAVE_FREEBSD_IEEE_INTERFACE
-#include "fp-freebsd.c"
+# if defined(__i386__) || defined(__x86_64__)
+#  include "fp-freebsd.c"
+# elif HAVE_DECL_FEENABLEEXCEPT || HAVE_DECL_FESETTRAPENABLE
+#  include "fp-gnuc99.c"
+# else
+#  include "fp-unknown.c"
+# endif
 #elif HAVE_OS2EMX_IEEE_INTERFACE
 #include "fp-os2emx.c"
 #elif HAVE_NETBSD_IEEE_INTERFACE
-- 
2.39.5
